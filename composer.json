{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "builtnoble/mezzio-inertia",
    "description": "Inertia.js adapter for Mezzio.",
    "type": "library",
    "authors": [
        {
            "name": "Amanda Romero",
            "email": "thetypescriptslayer@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "builtnoble/vite-php": "^0.1.0",
        "maskulabs/inertia-psr": "^3.0",
        "mezzio/mezzio-session": "^1.17",
        "mezzio/mezzio-template": "^3.0",
        "psr/http-factory": "^1.1"
    },
    "require-dev": {
        "laminas/laminas-diactoros": "^3.8",
        "laravel/pint": "^1.29",
        "mezzio/mezzio": "^3.28",
        "mrpunyapal/peststan": "^0.2.10",
        "pestphp/pest": "^4.7",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Builtnoble\\Mezzio\\Inertia\\": "src/"
        },
        "files": [
            "src/helpers.php",
            "src/Testing/Pest/Autoload.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Builtnoble\\Mezzio\\Inertia\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laminas": {
            "config-provider": "Builtnoble\\Mezzio\\Inertia\\ConfigProvider"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
